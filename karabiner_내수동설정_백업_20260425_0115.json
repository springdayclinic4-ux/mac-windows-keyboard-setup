{
    "global": {
        "check_for_updates_on_startup": true,
        "show_in_menu_bar": true,
        "show_profile_name_in_menu_bar": false
    },
    "profiles": [
        {
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": {
                "keyboard_type_v2": "ansi"
            },
            "simple_modifications": [],
            "complex_modifications": {
                "parameters": {
                    "basic.simultaneous_threshold_milliseconds": 50,
                    "basic.to_delayed_action_delay_milliseconds": 500,
                    "basic.to_if_alone_timeout_milliseconds": 1000,
                    "basic.to_if_held_down_threshold_milliseconds": 500
                },
                "rules": [
                    {
                        "description": "Windows 키 단축키 (좌측 Option = Win)",
                        "manipulators": [
                            { "type": "basic", "from": { "key_code": "e", "modifiers": { "mandatory": ["left_command"], "optional": ["caps_lock"] } }, "to": [{ "shell_command": "open -a Finder ~" }] },
                            { "type": "basic", "from": { "key_code": "d", "modifiers": { "mandatory": ["left_command"], "optional": ["caps_lock"] } }, "to": [{ "key_code": "mission_control" }] },
                            { "type": "basic", "from": { "key_code": "r", "modifiers": { "mandatory": ["left_command"], "optional": ["caps_lock"] } }, "to": [{ "key_code": "spacebar", "modifiers": ["left_command"] }] },
                            { "type": "basic", "from": { "key_code": "l", "modifiers": { "mandatory": ["left_command"], "optional": ["caps_lock"] } }, "to": [{ "key_code": "q", "modifiers": ["left_control", "left_command"] }] },
                            { "type": "basic", "from": { "key_code": "i", "modifiers": { "mandatory": ["left_command"], "optional": ["caps_lock"] } }, "to": [{ "shell_command": "open -a 'System Settings'" }] },
                            { "type": "basic", "from": { "key_code": "m", "modifiers": { "mandatory": ["left_command"], "optional": ["caps_lock"] } }, "to": [{ "key_code": "m", "modifiers": ["left_command"] }] },
                            { "type": "basic", "from": { "key_code": "tab", "modifiers": { "mandatory": ["left_command"], "optional": ["caps_lock"] } }, "to": [{ "key_code": "up_arrow", "modifiers": ["left_control"] }] },
                            { "type": "basic", "from": { "key_code": "s", "modifiers": { "mandatory": ["left_command", "left_shift"], "optional": ["caps_lock"] } }, "to": [{ "key_code": "4", "modifiers": ["left_command", "left_shift"] }] },
                            { "type": "basic", "from": { "key_code": "period", "modifiers": { "mandatory": ["left_command"], "optional": ["caps_lock"] } }, "to": [{ "key_code": "spacebar", "modifiers": ["left_control", "left_command"] }] },
                            { "type": "basic", "from": { "key_code": "left_arrow", "modifiers": { "mandatory": ["left_command"], "optional": ["caps_lock"] } }, "to": [{ "key_code": "left_arrow", "modifiers": ["left_control", "left_option"] }] },
                            { "type": "basic", "from": { "key_code": "right_arrow", "modifiers": { "mandatory": ["left_command"], "optional": ["caps_lock"] } }, "to": [{ "key_code": "right_arrow", "modifiers": ["left_control", "left_option"] }] },
                            { "type": "basic", "from": { "key_code": "up_arrow", "modifiers": { "mandatory": ["left_command"], "optional": ["caps_lock"] } }, "to": [{ "key_code": "return_or_enter", "modifiers": ["left_control", "left_option"] }] },
                            { "type": "basic", "from": { "key_code": "down_arrow", "modifiers": { "mandatory": ["left_command"], "optional": ["caps_lock"] } }, "to": [{ "key_code": "m", "modifiers": ["left_command"] }] }
                        ]
                    },
                    {
                        "description": "우측 Command → 한영 전환",
                        "manipulators": [
                            { "type": "basic", "from": { "key_code": "right_command", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "japanese_kana" }] }
                        ]
                    },
                    {
                        "description": "PC-Style Copy/Paste (Ctrl+C/V/X/Z/A → Cmd, 터미널 제외)",
                        "manipulators": [
                            { "type": "basic", "from": { "key_code": "c", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "c", "modifiers": ["left_command"] }], "conditions": [{ "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.apple\\.Terminal$", "^com\\.googlecode\\.iterm2$", "^co\\.zeit\\.hyper$", "^net\\.kovidgoyal\\.kitty$", "^org\\.alacritty$", "^com\\.github\\.wez\\.wezterm$", "^dev\\.warp\\.Warp-Stable$"] }] },
                            { "type": "basic", "from": { "key_code": "v", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "v", "modifiers": ["left_command"] }], "conditions": [{ "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.apple\\.Terminal$", "^com\\.googlecode\\.iterm2$", "^co\\.zeit\\.hyper$", "^net\\.kovidgoyal\\.kitty$", "^org\\.alacritty$", "^com\\.github\\.wez\\.wezterm$", "^dev\\.warp\\.Warp-Stable$"] }] },
                            { "type": "basic", "from": { "key_code": "x", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "x", "modifiers": ["left_command"] }], "conditions": [{ "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.apple\\.Terminal$", "^com\\.googlecode\\.iterm2$", "^co\\.zeit\\.hyper$", "^net\\.kovidgoyal\\.kitty$", "^org\\.alacritty$", "^com\\.github\\.wez\\.wezterm$", "^dev\\.warp\\.Warp-Stable$"] }] },
                            { "type": "basic", "from": { "key_code": "z", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "z", "modifiers": ["left_command"] }], "conditions": [{ "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.apple\\.Terminal$", "^com\\.googlecode\\.iterm2$", "^co\\.zeit\\.hyper$", "^net\\.kovidgoyal\\.kitty$", "^org\\.alacritty$", "^com\\.github\\.wez\\.wezterm$", "^dev\\.warp\\.Warp-Stable$"] }] },
                            { "type": "basic", "from": { "key_code": "a", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock"] } }, "to": [{ "key_code": "a", "modifiers": ["left_command"] }], "conditions": [{ "type": "frontmost_application_unless", "bundle_identifiers": ["^com\\.apple\\.Terminal$", "^com\\.googlecode\\.iterm2$", "^co\\.zeit\\.hyper$", "^net\\.kovidgoyal\\.kitty$", "^org\\.alacritty$", "^com\\.github\\.wez\\.wezterm$", "^dev\\.warp\\.Warp-Stable$"] }] }
                        ]
                    },
                    {
                        "description": "PC-Style Shortcuts (Ctrl+T/W/N/S/F/P/O/R/L/Y/B/I/U → Cmd)",
                        "manipulators": [
                            { "type": "basic", "from": { "key_code": "t", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "t", "modifiers": ["left_command"] }] },
                            { "type": "basic", "from": { "key_code": "w", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "w", "modifiers": ["left_command"] }] },
                            { "type": "basic", "from": { "key_code": "n", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "n", "modifiers": ["left_command"] }] },
                            { "type": "basic", "from": { "key_code": "s", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "s", "modifiers": ["left_command"] }] },
                            { "type": "basic", "from": { "key_code": "f", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "f", "modifiers": ["left_command"] }] },
                            { "type": "basic", "from": { "key_code": "p", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "p", "modifiers": ["left_command"] }] },
                            { "type": "basic", "from": { "key_code": "o", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "o", "modifiers": ["left_command"] }] },
                            { "type": "basic", "from": { "key_code": "r", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "r", "modifiers": ["left_command"] }] },
                            { "type": "basic", "from": { "key_code": "l", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "l", "modifiers": ["left_command"] }] },
                            { "type": "basic", "from": { "key_code": "y", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "y", "modifiers": ["left_command"] }] },
                            { "type": "basic", "from": { "key_code": "b", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "b", "modifiers": ["left_command"] }] },
                            { "type": "basic", "from": { "key_code": "i", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "i", "modifiers": ["left_command"] }] },
                            { "type": "basic", "from": { "key_code": "u", "modifiers": { "mandatory": ["left_control"], "optional": ["caps_lock", "shift"] } }, "to": [{ "key_code": "u", "modifiers": ["left_command"] }] }
                        ]
                    },
                    {
                        "description": "Ctrl + 방향키 → 단어 단위 이동 (Option+방향키)",
                        "manipulators": [
                            { "type": "basic", "from": { "key_code": "left_arrow", "modifiers": { "mandatory": ["left_control"], "optional": ["shift", "caps_lock"] } }, "to": [{ "key_code": "left_arrow", "modifiers": ["left_option"] }] },
                            { "type": "basic", "from": { "key_code": "right_arrow", "modifiers": { "mandatory": ["left_control"], "optional": ["shift", "caps_lock"] } }, "to": [{ "key_code": "right_arrow", "modifiers": ["left_option"] }] },
                            { "type": "basic", "from": { "key_code": "up_arrow", "modifiers": { "mandatory": ["left_control"], "optional": ["shift", "caps_lock"] } }, "to": [{ "key_code": "up_arrow", "modifiers": ["left_option"] }] },
                            { "type": "basic", "from": { "key_code": "down_arrow", "modifiers": { "mandatory": ["left_control"], "optional": ["shift", "caps_lock"] } }, "to": [{ "key_code": "down_arrow", "modifiers": ["left_option"] }] }
                        ]
                    },
                    {
                        "description": "Ctrl + Backspace/Delete → 단어 삭제",
                        "manipulators": [
                            { "type": "basic", "from": { "key_code": "delete_or_backspace", "modifiers": { "mandatory": ["left_control"], "optional": ["shift", "caps_lock"] } }, "to": [{ "key_code": "delete_or_backspace", "modifiers": ["left_option"] }] },
                            { "type": "basic", "from": { "key_code": "delete_forward", "modifiers": { "mandatory": ["left_control"], "optional": ["shift", "caps_lock"] } }, "to": [{ "key_code": "delete_forward", "modifiers": ["left_option"] }] }
                        ]
                    },
                    {
                        "description": "Home/End → 줄 처음/끝",
                        "manipulators": [
                            { "type": "basic", "from": { "key_code": "home", "modifiers": { "optional": ["shift", "caps_lock"] } }, "to": [{ "key_code": "left_arrow", "modifiers": ["left_command"] }] },
                            { "type": "basic", "from": { "key_code": "end", "modifiers": { "optional": ["shift", "caps_lock"] } }, "to": [{ "key_code": "right_arrow", "modifiers": ["left_command"] }] }
                        ]
                    },
                    {
                        "description": "Ctrl+Home/End → 문서 맨 위/아래",
                        "manipulators": [
                            { "type": "basic", "from": { "key_code": "home", "modifiers": { "mandatory": ["left_control"], "optional": ["shift", "caps_lock"] } }, "to": [{ "key_code": "up_arrow", "modifiers": ["left_command"] }] },
                            { "type": "basic", "from": { "key_code": "end", "modifiers": { "mandatory": ["left_control"], "optional": ["shift", "caps_lock"] } }, "to": [{ "key_code": "down_arrow", "modifiers": ["left_command"] }] }
                        ]
                    },
                    {
                        "description": "PrintScreen → 영역 스크린샷",
                        "manipulators": [
                            { "type": "basic", "from": { "key_code": "print_screen" }, "to": [{ "key_code": "4", "modifiers": ["left_command", "left_shift"] }] }
                        ]
                    },
                    {
                        "description": "Ctrl+Tab / Ctrl+Shift+Tab → 탭 전환",
                        "manipulators": [
                            { "type": "basic", "from": { "key_code": "tab", "modifiers": { "mandatory": ["left_control"] } }, "to": [{ "key_code": "right_arrow", "modifiers": ["left_command", "left_option"] }] },
                            { "type": "basic", "from": { "key_code": "tab", "modifiers": { "mandatory": ["left_control", "left_shift"] } }, "to": [{ "key_code": "left_arrow", "modifiers": ["left_command", "left_option"] }] }
                        ]
                    },
                    {
                        "description": "좌측 Option ↔ 좌측 Command 스왑 (마지막 처리)",
                        "manipulators": [
                            { "type": "basic", "from": { "key_code": "left_option", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "left_command" }] },
                            { "type": "basic", "from": { "key_code": "left_command", "modifiers": { "optional": ["any"] } }, "to": [{ "key_code": "left_option" }] }
                        ]
                    }
                ]
            }
        }
    ]
}
